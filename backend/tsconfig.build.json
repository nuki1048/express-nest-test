{
  "extends": "./tsconfig.json",
  "include": ["src/**/*"],
  "exclude": ["node_modules", "test", "dist", "prisma", "prisma.config.ts", "scripts", "**/*spec.ts"],
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "resolvePackageJsonExports": false,
    "noEmit": false,
    "incremental": false
  }
}
