{
  "extends": "./tsconfig.json",
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "prisma",
    "prisma.config.ts",
    "scripts",
    "**/*spec.ts",
    "src/admin"
  ],
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "noEmit": false,
    "incremental": false
  }
}
