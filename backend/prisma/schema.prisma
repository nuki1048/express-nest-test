// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id           String   @id @default(cuid())
  phoneNumbers String[]
  email        String
  address      Json     // { label: string, url: string }
  links        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactFormSubmission {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phoneNumber String
  message     String
  createdAt   DateTime @default(now())
}

model HolidayRental {
  id             String               @id @default(cuid())
  slug           String?              @unique
  title          String
  mainPhoto      String
  bedrooms       Int
  maxPeople      Int
  couches        Int
  showers        Int
  viewFromWindow String
  hasAc          Boolean              @default(false)
  translations   Json?
  variants       HolidayRentalVariant[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
}

model HolidayRentalVariant {
  id               String        @id @default(cuid())
  holidayRentalId  String
  holidayRental    HolidayRental  @relation(fields: [holidayRentalId], references: [id], onDelete: Cascade)
  title            String
  description      String        @db.Text
  airbnb           String?
  booking          String?
  bedrooms         Int
  maxPeople        Int
  couches          Int
  viewFromWindow   String
  hasAc            Boolean       @default(false)
  photos           String[]
  translations     Json?
  bookings         Booking[]
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([holidayRentalId])
}

model Booking {
  id                    String               @id @default(cuid())
  holidayRentalVariantId String
  holidayRentalVariant   HolidayRentalVariant @relation(fields: [holidayRentalVariantId], references: [id], onDelete: Cascade)
  startDate              DateTime
  endDate                DateTime
  guestName              String?
  notes                  String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@index([holidayRentalVariantId])
  @@index([startDate, endDate])
}

model YourFutureHome {
  id             String                  @id @default(cuid())
  slug           String?                 @unique
  title          String
  mainPhoto      String
  bedrooms       Int
  maxPeople      Int
  couches        Int
  showers        Int
  viewFromWindow String
  hasAc          Boolean                 @default(false)
  translations   Json?
  variants       YourFutureHomeVariant[]
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
}

model YourFutureHomeVariant {
  id                 String          @id @default(cuid())
  yourFutureHomeId   String
  yourFutureHome     YourFutureHome  @relation(fields: [yourFutureHomeId], references: [id], onDelete: Cascade)
  title              String
  description        String          @db.Text
  airbnb             String?
  booking            String?
  bedrooms           Int
  maxPeople          Int
  couches            Int
  viewFromWindow     String
  hasAc              Boolean         @default(false)
  photos             String[]
  translations       Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([yourFutureHomeId])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String?  @unique
  title         String
  description   String   @db.Text
  content       String   @db.Text
  mainPhoto     String
  readTime      String?
  translations  Json?   
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         Int      @default(0)
  likes         Int      @default(0)
  isPublished   Boolean  @default(false)
}
