// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id           String   @id @default(cuid())
  phoneNumbers String[]
  email        String
  address      Json     // { label: string, url: string }
  links        Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContactFormSubmission {
  id          String   @id @default(cuid())
  firstName   String
  lastName    String
  email       String
  phoneNumber String
  message     String
  createdAt   DateTime @default(now())
}

model HolidayRental {
  id           String               @id @default(cuid())
  slug         String?              @unique
  title        String
  description  String                @db.Text
  mainPhoto    String
  airbnb       String?
  booking      String?
  translations Json?
  variants     HolidayRentalVariant[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model HolidayRentalVariant {
  id               String        @id @default(cuid())
  holidayRentalId  String
  holidayRental    HolidayRental  @relation(fields: [holidayRentalId], references: [id], onDelete: Cascade)
  bedrooms         Int
  maxPeople        Int
  couches          Int
  showers          Int
  viewFromWindow   String
  hasAc            Boolean       @default(false)
  photos           String[]
  translations     Json?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([holidayRentalId])
}

model YourFutureHome {
  id           String                  @id @default(cuid())
  slug         String?                 @unique
  title        String
  description  String                   @db.Text
  mainPhoto    String
  airbnb       String?
  booking      String?
  translations Json?
  variants     YourFutureHomeVariant[]
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
}

model YourFutureHomeVariant {
  id                 String          @id @default(cuid())
  yourFutureHomeId   String
  yourFutureHome     YourFutureHome  @relation(fields: [yourFutureHomeId], references: [id], onDelete: Cascade)
  bedrooms           Int
  maxPeople          Int
  couches            Int
  showers            Int
  viewFromWindow     String
  hasAc              Boolean         @default(false)
  photos             String[]
  translations       Json?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([yourFutureHomeId])
}

model BlogPost {
  id            String   @id @default(cuid())
  slug          String?  @unique
  title         String
  description   String   @db.Text
  content       String   @db.Text
  mainPhoto     String
  readTime      String?
  translations  Json?   
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  views         Int      @default(0)
  likes         Int      @default(0)
  isPublished   Boolean  @default(false)
}
