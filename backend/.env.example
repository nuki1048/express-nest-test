# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://USER@localhost:5432/appartaments_rent"
NODE_ENV=development
PORT=3000

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me
ADMIN_SESSION_SECRET=change-me-in-production

# Required for Vercel/serverless: AdminJS cannot write temp bundle files in read-only env
ADMIN_JS_SKIP_BUNDLE=true
# Optional: URL to pre-bundled AdminJS assets (required if using custom components)
# ADMIN_JS_ASSETS_CDN=https://your-cdn.com/admin-assets/

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key